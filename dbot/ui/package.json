{
  "name": "dbot-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check --config-path ../../biome.json src/",
    "lint:fix": "biome check --write --config-path ../../biome.json src/",
    "format": "biome format --write --config-path ../../biome.json src/",
    "check": "biome ci --config-path ../../biome.json src/ && tsc -b --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "^1.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
